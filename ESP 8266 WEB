#include <ESP8266WiFi.h>
#include <ESP8266WebServer.h>
#include <HX711_ADC.h>

// ===== LOAD CELL =====
HX711_ADC LoadCell(D3, D4);

// ===== RPM SENSOR =====
#define RPM_PIN D2
volatile int pulseCount = 0;
unsigned long lastRPMTime = 0;
float rpm = 0;

// ===== WIFI =====
const char* ssid = "PC integrated lab";
const char* password = "12345678";

ESP8266WebServer server(80);

// ===== MOTOR =====
#define mot_rly D7
#define mot_A D5
#define mot_B D6

// ===== VARIABLES =====
float V=0,I=0,T=0,loadValue=0;
String motor_stat="STOPPED";
String data_in;

int stepsPerRotation = 7;

// ===== RPM INTERRUPT =====
void IRAM_ATTR countPulse(){
  pulseCount++;
}

