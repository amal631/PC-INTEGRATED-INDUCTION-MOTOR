// ================= HANDLERS =================
void handleRoot(){ server.send(200,"text/html",webpage); }

void handleData(){
String json="{";
json+="\"voltage\":"+String(V)+",";
json+="\"current\":"+String(I)+",";
json+="\"temp\":"+String(T)+",";
json+="\"load\":"+String(loadValue)+",";
json+="\"rpm\":"+String(rpm)+",";
json+="\"motor\":\""+motor_stat+"\"}";
server.send(200,"application/json",json);
}

// ================= SETUP =================
void setup(){

Serial.begin(9600);

LoadCell.begin();
LoadCell.start(2000);
LoadCell.setCalFactor(999.0);

pinMode(mot_rly,OUTPUT);
pinMode(mot_A,OUTPUT);
pinMode(mot_B,OUTPUT);

pinMode(RPM_PIN,INPUT_PULLUP);
attachInterrupt(digitalPinToInterrupt(RPM_PIN),countPulse,RISING);

WiFi.softAP(ssid,password);

server.on("/",handleRoot);
server.on("/data",handleData);

server.on("/motor_on",[](){digitalWrite(mot_rly,HIGH);motor_stat="RUNNING";server.send(200,"text","OK");});
server.on("/ext_off",[](){digitalWrite(mot_rly,LOW);motor_stat="STOPPED";server.send(200,"text","OK");});

server.on("/load_inc",[](){
for(int i=0;i<7;i++){
digitalWrite(mot_A,LOW);digitalWrite(mot_B,HIGH);
delay(1000);
digitalWrite(mot_A,LOW);digitalWrite(mot_B,LOW);
delay(200);
}
server.send(200,"text","OK");
});

server.on("/load_dec",[](){
for(int i=0;i<7;i++){
digitalWrite(mot_A,HIGH);digitalWrite(mot_B,LOW);
delay(1000);
digitalWrite(mot_A,LOW);digitalWrite(mot_B,LOW);
delay(200);
}
server.send(200,"text","OK");
});

server.begin();
}

// ================= LOOP =================
void loop(){

server.handleClient();

LoadCell.update();
loadValue=LoadCell.getData();

// RPM
if(millis()-lastRPMTime>=1000){
rpm=pulseCount*60;
pulseCount=0;
lastRPMTime=millis();
}

// SERIAL
if(Serial.available()){
data_in=Serial.readStringUntil('\n');

if(data_in.startsWith("#")){
int p1=data_in.indexOf(',');
int p2=data_in.indexOf(',',p1+1);

I=data_in.substring(1,p1).toFloat();
V=data_in.substring(p1+1,p2).toFloat();
T=data_in.substring(p2+1).toFloat();
}
}

}
